{
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/stories/:path*",
            "destination": "/stories/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        {
            "source": "/:slug",
            "destination": "/story.html"
        }
    ],
    "includeFiles": [
        "public/stories/**"
    ]
}