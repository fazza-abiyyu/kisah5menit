{
    "version": 2,
    "builds": [
        {
            "src": "src/server/app.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "public/stories/**"
                ]
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/src/server/app.ts"
        },
        {
            "source": "/stories/:path*",
            "destination": "/stories/:path*"
        },
        {
            "source": "/:slug",
            "destination": "/story.html"
        }
    ]
}