{
    "version": 2,
    "functions": {
        "api/index.ts": {
            "includeFiles": "public/stories/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index"
        },
        {
            "source": "/:slug",
            "destination": "/pages/:slug.html"
        }
    ]
}